{
  "name": "@radvault/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "prisma generate --config ./prisma.config.ts",
    "prelint": "npm run -w @radvault/types build && prisma generate --config ./prisma.config.ts",
    "pretypecheck": "npm run -w @radvault/types build && prisma generate --config ./prisma.config.ts",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPattern=src",
    "test:integration": "jest --config jest.config.ts --testPathPattern=test",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "openapi:generate": "tsx scripts/verify-openapi.ts --generate-only",
    "openapi:verify": "tsx scripts/verify-openapi.ts",
    "prisma:generate": "prisma generate --config ./prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config ./prisma.config.ts",
    "prisma:deploy": "prisma migrate deploy --config ./prisma.config.ts"
  },
  "dependencies": {
    "@nestjs/bull": "11.0.4",
    "@nestjs/common": "11.1.15",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.15",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.15",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.212.0",
    "@opentelemetry/sdk-node": "0.212.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "7.4.2",
    "@radvault/types": "*",
    "@willsoto/nestjs-prometheus": "6.0.2",
    "bcrypt": "6.0.0",
    "bullmq": "5.70.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "dcmjs": "0.45.0",
    "nest-winston": "1.10.2",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "^8.19.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "tsx": "4.20.6",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.15",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.5",
    "@types/jest": "29.5.14",
    "@types/node": "24.10.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "6.0.3",
    "jest": "29.7.0",
    "prisma": "7.4.2",
    "supertest": "7.1.4",
    "ts-jest": "29.4.5",
    "typescript": "5.9.3"
  }
}
