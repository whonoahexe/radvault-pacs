# ──────────────────────────────────────────────
# RadVault PACS — Environment Variables
# cp .env.example .env && docker compose up --build
# ──────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=radvault
POSTGRES_PASSWORD=radvault_dev_password
POSTGRES_DB=radvault
DATABASE_URL=postgresql://radvault:radvault_dev_password@postgres:5432/radvault?schema=public

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO / S3 ────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=radvault-dicom

# ── JWT ───────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── Orthanc ───────────────────────────────────
ORTHANC_URL=http://orthanc:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc

# ── OpenTelemetry / Jaeger ────────────────────
OTEL_SERVICE_NAME=radvault-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

# ── Grafana ───────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Application ──────────────────────────────
API_PORT=3000
WEB_PORT=3000
NODE_ENV=development
